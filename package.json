{
  "name": "steam-mobile",
  "version": "0.9.3",
  "private": true,
  "type": "module",
  "description": "Headless Steam mobile-app client (web-based, no CM) for trading.",
  "author": "bekesibeni",
  "homepage": "https://github.com/bekesibeni/steam-mobile#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bekesibeni/steam-mobile.git"
  },
  "bugs": {
    "url": "https://github.com/bekesibeni/steam-mobile/issues"
  },
  "packageManager": "pnpm@11.1.1",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "proto": "buf generate",
    "bootstrap": "tsx debug/bootstrap.ts",
    "smoke": "tsx debug/smoke.ts",
    "watch": "tsx debug/watch.ts",
    "trade": "tsx debug/trade.ts",
    "partner-inventory": "tsx debug/partnerInventory.ts",
    "own-inventory": "tsx debug/ownInventory.ts",
    "trade-eligibility": "tsx debug/webTradeEligibility.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "got": "^15.0.5",
    "proxy-agent": "^8.0.1",
    "steamid": "^2.1.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@bufbuild/buf": "^1.70.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/node": "^22",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
