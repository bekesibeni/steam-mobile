{
  "name": "@assetpay/steam-mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Headless Steam mobile-app client (web-based, no CM) for trading.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "m0": "tsx debug/m0-tokens-test.ts",
    "m1": "tsx debug/m1-live-test.ts",
    "m2": "tsx debug/m2-live-test.ts",
    "ratelimit": "tsx debug/ratelimit-test.ts",
    "ratehist": "tsx debug/ratelimit-history.ts",
    "test:iecon": "tsx debug/test-iecon.ts"
  },
  "dependencies": {
    "got": "^15.0.5",
    "proxy-agent": "^8.0.1",
    "steam-totp": "^2.1.2",
    "steamid": "^2.1.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24",
    "steam-session": "^1.9.4",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
